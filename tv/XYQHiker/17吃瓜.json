{
  "name": "示",
  "host": "https://jpm.yzfnb2.makeup/cn/home/web",
  "type": "video",
  
  // 1. 分类板块（新增）
  "category": {
    "url": "https://jpm.yzfnb2.makeup/cn/home/web/index.php/vod/{cateId}--------{page}---.html",
    "arrays": "div.module-item",
    "title": "a&&title",
    "cover": "img&&data-src",
    "url": "a&&href",
    "hasMore": true
  },

  // 2. 搜索板块
  "search": {
    "url": "https://jpm.yzfnb2.makeup/cn/home/web/index.php/vod/search?wd={wd}",
    "arrays": "div.module-item",
    "title": "a&&title",
    "cover": "img&&data-src",
    "url": "a&&href"
  },

  // 3. 详情页板块
  "detail": {
    "title": "h1&&Text",
    "cover": ".poster&&src",
    "desc": ".summary&&Text"
  },

  // 4. 播放嗅探板块
  "play": {
    "url": "https://jpm.yzfnb2.makeup/cn/home/web/index.php/vod/play",
    "webview": true,
    "sourceRegex": "(.m3u8|.mp4)",
    "notSourceRegex": "(ad|banner|m3u8.js)",
    "webviewJsDelay": 5000
  }
}
